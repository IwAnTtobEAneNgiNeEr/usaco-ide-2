# USACO IDE 2.0 — optional environment variables
# ---------------------------------------------------------------------------
# Copy this file to ".env" ONLY if you need to override the defaults below.
# The app runs fine with NO .env at all — every value here has a sane default.
#
# NOTE: Your AI API key is NOT configured here. It is entered in the app
# (Settings -> AI) and stored locally in data/ai-settings.json (gitignored,
# never logged). Do not put secrets in this file or in the repo.
# ---------------------------------------------------------------------------

# Port the local web server listens on (default 5050).
# The launchers and the Electron desktop wrapper read this too.
USACO_IDE_PORT=5050

# Host/interface to bind. Default 127.0.0.1 (loopback only — recommended).
# Binding a non-loopback address (e.g. 0.0.0.0) is an explicit opt-in for LAN
# use and disables the loopback-only DNS-rebinding guard. Do this only on a
# trusted network: the server compiles and runs arbitrary C++.
USACO_IDE_HOST=127.0.0.1

# Competitive Companion browser-extension listener port (default 10043).
# Set to 0 to disable the listener entirely.
USACO_COMPANION_PORT=10043
